---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  path?: string;
  ogType?: string;
  jsonLd?: string;
}

const site = 'https://agesdk.dev';
const { title, description, path = '/', ogType = 'website', jsonLd } = Astro.props;
const url = `${site}${path}`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="AgeSignal" />
    <link rel="canonical" href={url} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:site_name" content="AgeSignal" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" />

    {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}
  </head>
  <body>
    <slot />
  </body>
</html>
