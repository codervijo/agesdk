---
import Icon from './Icon.astro';
const { pathname } = Astro.url;
const isActive = (p: string) => pathname === p || pathname === p + '/';
---
<header class="sticky top-0 z-40 border-b border-border/60 bg-background/70 backdrop-blur-xl">
  <div class="mx-auto flex h-14 max-w-6xl items-center justify-between px-4 sm:px-6">
    <a href="/" class="flex items-center gap-2 font-semibold tracking-tight">
      <span class="grid size-7 place-items-center rounded-md bg-gradient-brand shadow-glow">
        <Icon name="shield" class="size-4 text-primary-foreground" />
      </span>
      <span>AgeSignal</span>
    </a>
    <nav class="hidden md:flex items-center gap-7 text-sm text-muted-foreground">
      <a href="/docs" class={`hover:text-foreground transition ${isActive('/docs') ? 'text-foreground' : ''}`}>Docs</a>
      <a href="/checklist" class={`hover:text-foreground transition ${isActive('/checklist') ? 'text-foreground' : ''}`}>Checklist</a>
      <a href="/pricing" class={`hover:text-foreground transition ${isActive('/pricing') ? 'text-foreground' : ''}`}>Pricing</a>
      <a href="/#faq" class="hover:text-foreground transition">FAQ</a>
    </nav>
    <div class="flex items-center gap-2">
      <a href="/#waitlist">
        <button class="inline-flex items-center justify-center rounded-md text-sm font-medium h-9 px-3 bg-gradient-brand text-primary-foreground hover:opacity-90 shadow-glow">
          Join waitlist
        </button>
      </a>
    </div>
  </div>
</header>
