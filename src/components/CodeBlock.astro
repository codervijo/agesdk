---
import Icon from './Icon.astro';

interface Props {
  code: string;
  language?: string;
  filename?: string;
  class?: string;
}
const { code, language = 'tsx', filename, class: className = '' } = Astro.props;
const label = filename ?? language;
---
<div class={`code-block group rounded-xl border border-code-border bg-code-bg overflow-hidden text-sm shadow-2xl shadow-black/40 ${className}`}>
  <div class="flex items-center justify-between border-b border-code-border px-4 py-2.5 bg-black/20">
    <div class="flex items-center gap-2">
      <div class="flex gap-1.5">
        <span class="size-2.5 rounded-full bg-red-500/60"></span>
        <span class="size-2.5 rounded-full bg-yellow-500/60"></span>
        <span class="size-2.5 rounded-full bg-green-500/60"></span>
      </div>
      <span class="ml-3 text-xs text-muted-foreground font-mono">{label}</span>
    </div>
    <button
      type="button"
      data-copy-code={code}
      class="copy-btn text-muted-foreground hover:text-foreground transition opacity-0 group-hover:opacity-100"
      aria-label="Copy code"
    >
      <Icon name="copy" class="size-4 icon-copy" />
      <Icon name="check" class="size-4 icon-check hidden" />
    </button>
  </div>
  <pre class="p-4 overflow-x-auto leading-relaxed text-foreground/90"><code>{code}</code></pre>
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const code = btn.dataset.copyCode ?? '';
      try {
        await navigator.clipboard.writeText(code);
        const copyIcon = btn.querySelector('.icon-copy');
        const checkIcon = btn.querySelector('.icon-check');
        copyIcon?.classList.add('hidden');
        checkIcon?.classList.remove('hidden');
        setTimeout(() => {
          copyIcon?.classList.remove('hidden');
          checkIcon?.classList.add('hidden');
        }, 1500);
      } catch {}
    });
  });
</script>
