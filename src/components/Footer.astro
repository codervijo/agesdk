---
import Icon from './Icon.astro';
const year = new Date().getFullYear();
---
<footer class="border-t border-border/60 mt-24">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 py-12 grid gap-8 md:grid-cols-4 text-sm">
    <div class="md:col-span-2">
      <div class="flex items-center gap-2 font-semibold">
        <span class="grid size-6 place-items-center rounded-md bg-gradient-brand">
          <Icon name="shield" class="size-3.5 text-primary-foreground" />
        </span>
        AgeSignal
      </div>
      <p class="mt-3 text-muted-foreground max-w-sm">
        Age-aware app behavior for Expo. Developer infrastructure, not legal advice.
      </p>
      <p class="mt-3 text-xs text-muted-foreground/70">agesdk.dev</p>
    </div>
    <div>
      <div class="font-medium mb-3">Product</div>
      <ul class="space-y-2 text-muted-foreground">
        <li><a href="/docs" class="hover:text-foreground">Docs</a></li>
        <li><a href="/pricing" class="hover:text-foreground">Pricing</a></li>
        <li><a href="/checklist" class="hover:text-foreground">Checklist</a></li>
      </ul>
    </div>
    <div>
      <div class="font-medium mb-3">Legal</div>
      <ul class="space-y-2 text-muted-foreground">
        <li>Developer infrastructure</li>
        <li>Not legal advice</li>
      </ul>
    </div>
  </div>
  <div class="border-t border-border/60 py-5 text-center text-xs text-muted-foreground">
    © {year} AgeSignal. Built for Expo & React Native developers.
  </div>
</footer>
